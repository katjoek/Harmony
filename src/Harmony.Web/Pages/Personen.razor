@page "/personen"
@using Harmony.ApplicationCore.DTOs
@using Harmony.ApplicationCore.Queries.Persons
@using Harmony.ApplicationCore.Commands.Persons
@using Harmony.Web.Models
@using LiteBus.Commands.Abstractions
@using LiteBus.Queries.Abstractions
@using System.Linq

<PageTitle>Personen - Harmony</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Personen</h1>
    <div class="d-flex gap-2">
        <SearchBar Id="person-search-input" @bind-Value="personSearch" />
        <button type="button" class="btn btn-primary" data-testid="new-person-btn" @onclick="OpenCreateModal">
            <i class="fas fa-plus me-2"></i>
            Nieuwe Persoon
        </button>
    </div>
</div>

@if (persons != null)
{
    <div class="mb-2">
        @if (string.IsNullOrWhiteSpace(personSearch))
        {
            <span class="text-muted">@persons.Count @(persons.Count == 1 ? "persoon" : "personen")</span>
        }
        else
        {
            <span class="text-muted">@FilteredPersons.Count() @(FilteredPersons.Count() == 1 ? "persoon" : "personen") gevonden</span>
        }
    </div>
}

<!-- Always show the table structure immediately for fast rendering -->
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th style="cursor: pointer; user-select: none;" @onclick="ToggleSortOrder" title="Klik om sorteervolgorde te wijzigen">
                    <span>Naam (</span>
                        <i class="fas fa-sort-alpha-down ms-1" style="font-size: 0.75em; color: #6c757d;"></i>
                    @if (personSortOrder == "FirstName")
                    {
                        <span>V</span>
                    }
                    else
                    {
                        <span>A</span>
                    }
                    <span>)</span>
                </th>
                <th>Geboortedatum</th>
                <th>Adres</th>
                <th>Telefoon</th>
                <th>E-mail</th>
                <th>&#35; Groepen</th>
                <th>Acties</th>
            </tr>
        </thead>
        <tbody>
            @if (persons == null)
            {
                <!-- Skeleton loading rows for instant feedback -->
                @for (int i = 0; i < 5; i++)
                {
                    <tr>
                        <td><div class="placeholder-glow"><span class="placeholder col-8"></span></div></td>
                        <td><div class="placeholder-glow"><span class="placeholder col-6"></span></div></td>
                        <td><div class="placeholder-glow"><span class="placeholder col-10"></span></div></td>
                        <td><div class="placeholder-glow"><span class="placeholder col-7"></span></div></td>
                        <td><div class="placeholder-glow"><span class="placeholder col-9"></span></div></td>
                        <td><div class="placeholder-glow"><span class="placeholder col-3"></span></div></td>
                        <td>
                            <div class="btn-group" role="group">
                                <button type="button" class="btn btn-sm btn-secondary" disabled>
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-secondary" disabled>
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else if (persons.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">Geen personen gevonden.</td>
                </tr>
            }
            else if (!FilteredPersons.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">Geen resultaten voor "@personSearch".</td>
                </tr>
            }
            else
            {
                @foreach (var person in FilteredPersons)
                {
                    <tr title="@GetPersonGroupsTooltip(person)">
                        <td>@GetDisplayName(person)</td>
                        <td>@person.DateOfBirth?.ToString("dd-MM-yyyy")</td>
                        <td>@person.FormattedAddress</td>
                        <td>@person.PhoneNumber</td>
                        <td>@person.EmailAddress</td>
                        <td class="text-center" data-testid="group-count">
                            @person.GroupIds.Count
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <button type="button" class="btn btn-sm btn-info" title="Groepen" data-testid="groups-btn" @onclick="@(() => OpenGroupsModal(person))">
                                    <i class="fas fa-users"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-primary" @onclick="@(() => OpenEditModal(person))">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-danger" @onclick="@(() => DeletePerson(person))">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Groups Membership Modal Component -->
@if (selectedPerson != null && personGroups != null && availableGroups != null)
{
    <DualListMembershipModal
        Show="@showGroupsModal"
        Title="@($"Groepen van {selectedPerson.FullName}")"
        LeftLabel="Beschikbare groepen"
        RightLabel="@($"Lid van")"
        LeftSelectId="person-available-groups"
        RightSelectId="person-member-groups"
        LeftItems="@availableGroups.Select(g => new Harmony.Web.Models.DualListItem(g.Id, g.Name)).ToList()"
        RightItems="@personGroups.Select(g => new Harmony.Web.Models.DualListItem(g.Id, g.Name)).ToList()"
        IsBusy="@isProcessingGroups"
        Close="@CloseGroupsModal"
        MoveLeftToRight="@MoveAvailableGroupsToMember"
        MoveRightToLeft="@MoveMemberGroupsToAvailable" />
}

<PersonFormModal
    Show="@showPersonModal"
    Title="@modalTitle"
    Model="@personModel"
    OnSave="@SavePerson"
    OnClose="@CloseModal" />

@code {
    private List<PersonDto>? persons;
    private PersonViewModel personModel = new();
    private string modalTitle = "";
    private bool isEditing = false;
    private bool showPersonModal = false;
    private string personSearch = "";
    private string personSortOrder = "LastName";

    // Groups modal state
    private bool showGroupsModal = false;
    private PersonDto? selectedPerson;
    private List<GroupDto>? allGroups;
    private List<GroupDto>? personGroups;
    private List<GroupDto>? availableGroups;
    private List<string> selectedAvailableGroupIds = new();
    private List<string> selectedMemberGroupIds = new();
    private bool isProcessingGroups = false;

    protected override Task OnInitializedAsync()
    {
        _ = Task.Run(async () =>
        {
            try
            {
                await LoadPersons();
                await LoadGroups();
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error loading persons");
            }
        });
        return Task.CompletedTask;
    }

    private async Task LoadPersons()
    {
        persons = (await QueryMediator.QueryAsync(new GetAllPersonsQuery())).ToList();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadGroups()
    {
        allGroups = (await QueryMediator.QueryAsync(new Harmony.ApplicationCore.Queries.Groups.GetAllGroupsQuery())).ToList();
        await InvokeAsync(StateHasChanged);
    }

    private string GetPersonGroupsTooltip(PersonDto person)
    {
        if (allGroups == null) return string.Empty;
        if (!person.GroupIds.Any()) return "Geen groepen";

        var groupNames = allGroups
            .Where(g => person.GroupIds.Contains(g.Id))
            .Select(g => g.Name)
            .OrderBy(n => n, StringComparer.OrdinalIgnoreCase)
            .ToList();

        return groupNames.Any()
            ? $"Groepen: {string.Join(", ", groupNames)}"
            : "Geen groepen";
    }

    private void OpenCreateModal()
    {
        personModel = new PersonViewModel();
        modalTitle = "Nieuwe Persoon";
        isEditing = false;
        showPersonModal = true;
    }

    private async Task OpenGroupsModal(PersonDto person)
    {
        selectedPerson = person;
        await LoadGroups();
        LoadPersonGroups();
        UpdateAvailableGroups();
        showGroupsModal = true;
    }

    private void LoadPersonGroups()
    {
        if (allGroups == null || selectedPerson == null) return;
        var set = selectedPerson.GroupIds.ToHashSet();
        personGroups = allGroups
            .Where(g => set.Contains(g.Id))
            .OrderBy(g => g.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private void UpdateAvailableGroups()
    {
        if (allGroups == null || personGroups == null) return;
        var member = personGroups.Select(g => g.Id).ToHashSet();
        availableGroups = allGroups
            .Where(g => !member.Contains(g.Id))
            .OrderBy(g => g.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
        selectedAvailableGroupIds.Clear();
        selectedMemberGroupIds.Clear();
    }

    private void CloseGroupsModal()
    {
        showGroupsModal = false;
        selectedPerson = null;
        personGroups = null;
        availableGroups = null;
        selectedAvailableGroupIds.Clear();
        selectedMemberGroupIds.Clear();
    }

    private async Task MoveAvailableGroupsToMember(IEnumerable<string> groupIds)
    {
        if (selectedPerson == null) return;
        var ids = groupIds?.ToArray() ?? Array.Empty<string>();
        if (ids.Length == 0) return;
        try
        {
            isProcessingGroups = true;
            foreach (var gid in ids)
                await CommandMediator.SendAsync(new Harmony.ApplicationCore.Commands.Membership.AddPersonToGroupCommand(selectedPerson.Id, gid));
            await RefreshGroupsState();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Fout bij toevoegen aan groepen");
        }
        finally
        {
            isProcessingGroups = false;
        }
    }

    private async Task MoveMemberGroupsToAvailable(IEnumerable<string> groupIds)
    {
        if (selectedPerson == null) return;
        var ids = groupIds?.ToArray() ?? Array.Empty<string>();
        if (ids.Length == 0) return;
        try
        {
            isProcessingGroups = true;
            foreach (var gid in ids)
                await CommandMediator.SendAsync(new Harmony.ApplicationCore.Commands.Membership.RemovePersonFromGroupCommand(selectedPerson.Id, gid));
            await RefreshGroupsState();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Fout bij verwijderen uit groepen");
        }
        finally
        {
            isProcessingGroups = false;
        }
    }

    private async Task RefreshGroupsState()
    {
        if (selectedPerson == null) return;
        var selectedPersonId = selectedPerson.Id;
        await LoadPersons();
        await LoadGroups();
        selectedPerson = persons?.FirstOrDefault(p => p.Id == selectedPersonId);
        if (selectedPerson == null) return;
        LoadPersonGroups();
        UpdateAvailableGroups();
        StateHasChanged();
    }

    private void OpenEditModal(PersonDto person)
    {
        personModel = new PersonViewModel
        {
            Id = person.Id,
            FirstName = person.FirstName,
            Prefix = person.Prefix,
            Surname = person.Surname,
            DateOfBirth = person.DateOfBirth,
            Street = person.Street,
            ZipCode = person.ZipCode,
            City = person.City,
            PhoneNumber = person.PhoneNumber,
            EmailAddress = person.EmailAddress
        };
        modalTitle = "Persoon Bewerken";
        isEditing = true;
        showPersonModal = true;
    }

    private async Task SavePerson()
    {
        try
        {
            if (isEditing)
            {
                await CommandMediator.SendAsync(new UpdatePersonCommand(
                    personModel.Id!,
                    personModel.FirstName!,
                    personModel.Prefix,
                    personModel.Surname,
                    personModel.DateOfBirth,
                    personModel.Street,
                    personModel.ZipCode,
                    personModel.City,
                    personModel.PhoneNumber,
                    personModel.EmailAddress));
            }
            else
            {
                await CommandMediator.SendAsync(new CreatePersonCommand(
                    personModel.FirstName!,
                    personModel.Prefix,
                    personModel.Surname,
                    personModel.DateOfBirth,
                    personModel.Street,
                    personModel.ZipCode,
                    personModel.City,
                    personModel.PhoneNumber,
                    personModel.EmailAddress));
            }

            await LoadPersons();
            CloseModal();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Fout bij opslaan persoon");
        }
    }

    private async Task DeletePerson(PersonDto person)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"Weet u zeker dat u {person.FullName} wilt verwijderen?"))
        {
            try
            {
                await CommandMediator.SendAsync(new DeletePersonCommand(person.Id));
                await LoadPersons();
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Fout bij verwijderen persoon");
            }
        }
    }

    private void CloseModal() => showPersonModal = false;

    private IEnumerable<PersonDto> FilteredPersons
    {
        get
        {
            var filtered = string.IsNullOrWhiteSpace(personSearch) || persons == null
                ? persons ?? Enumerable.Empty<PersonDto>()
                : persons.Where(p => MatchesPerson(p, personSearch));

            return personSortOrder == "FirstName"
                ? filtered.OrderBy(p => p.FirstName, StringComparer.OrdinalIgnoreCase).ThenBy(p => p.Surname ?? "", StringComparer.OrdinalIgnoreCase)
                : filtered.OrderBy(p => p.Surname ?? "", StringComparer.OrdinalIgnoreCase).ThenBy(p => p.FirstName, StringComparer.OrdinalIgnoreCase);
        }
    }

    private static bool MatchesPerson(PersonDto p, string term)
    {
        var t = term.Trim();
        return ContainsInsensitive(p.FullName, t)
            || ContainsInsensitive(p.City, t)
            || ContainsInsensitive(p.ZipCode, t)
            || ContainsInsensitive(p.Street, t)
            || ContainsInsensitive(p.PhoneNumber, t)
            || ContainsInsensitive(p.EmailAddress, t)
            || (p.DateOfBirth?.ToString("dd-MM-yyyy").Contains(t, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private static bool ContainsInsensitive(string? haystack, string needle)
        => !string.IsNullOrWhiteSpace(haystack) && haystack.Contains(needle, StringComparison.OrdinalIgnoreCase);

    private void ToggleSortOrder()
    {
        personSortOrder = personSortOrder == "FirstName" ? "LastName" : "FirstName";
        StateHasChanged();
    }

    private string GetDisplayName(PersonDto person)
    {
        if (personSortOrder == "FirstName")
            return person.FullName;

        var firstNameWithPrefix = string.Join(" ", new[] { person.FirstName, person.Prefix }.Where(x => !string.IsNullOrEmpty(x)));
        if (string.IsNullOrEmpty(person.Surname))
            return firstNameWithPrefix;
        return $"{person.Surname}, {firstNameWithPrefix}";
    }
}

@inject ICommandMediator CommandMediator
@inject IQueryMediator QueryMediator
@inject IJSRuntime JSRuntime
@inject ILogger<Personen> Logger
