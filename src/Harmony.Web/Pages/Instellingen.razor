@page "/instellingen"
@using Harmony.ApplicationCore.Interfaces
@using Harmony.Web.Services

<PageTitle>Instellingen - Harmony</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Instellingen</h1>
</div>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-8">
        <!-- Database Directory Section -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-database me-2"></i>
                    Database Locatie
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Huidige database map:</label>
                    <div class="input-group">
                        <input type="text" class="form-control" value="@databasePath" readonly />
                        <button type="button" class="btn btn-outline-secondary" @onclick="CopyDatabasePath" title="Kopieer pad">
                            <i class="fas fa-copy"></i>
                        </button>
                    </div>
                </div>
                <p class="text-muted small mb-0">
                    De database wordt opgeslagen in de bovenstaande map als <code>harmony.db</code>. Om de locatie te wijzigen, verwijder het bestand <code>harmony.settings.json</code> uit de applicatiemap en start de applicatie opnieuw.
                </p>
            </div>
        </div>

        <!-- Server Binding Section -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-network-wired me-2"></i>
                    Server Netwerk Instellingen
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Wie kan de server benaderen?</label>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="serverBinding" id="localhostOnly"
                               checked="@(!listenOnAllInterfaces)"
                               @onchange="@(() => UpdateServerBinding(false))" />
                        <label class="form-check-label" for="localhostOnly">
                            <strong>Alleen deze computer (aanbevolen)</strong>
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="serverBinding" id="allInterfaces"
                               checked="@listenOnAllInterfaces"
                               @onchange="@(() => UpdateServerBinding(true))" />
                        <label class="form-check-label" for="allInterfaces">
                            <strong>Alle computers in het netwerk</strong>
                        </label>
                    </div>
                </div>
                <div class="alert alert-info mb-0">
                    <div class="small">
                        <strong>Uitleg:</strong>
                        <ul class="mb-0 mt-2">
                            <li><strong>Alleen deze computer:</strong> De server is alleen bereikbaar vanaf deze computer zelf.
                                Andere computers in uw netwerk kunnen de applicatie niet gebruiken. Dit is de veiligste optie.</li>
                            <li><strong>Alle computers in het netwerk:</strong> De server is bereikbaar vanaf alle computers
                                die met hetzelfde netwerk verbonden zijn. Andere computers kunnen de applicatie gebruiken door
                                het IP-adres van deze computer te gebruiken. <strong>Let op:</strong> Dit kan een beveiligingsrisico zijn
                                als uw netwerk niet goed beveiligd is.</li>
                        </ul>
                        <div class="mt-2">
                            <strong>Belangrijk:</strong> Wijzigingen aan deze instelling worden pas actief na het opnieuw opstarten van de applicatie.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <BackupCard />

        <!-- Software Update Section -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-sync-alt me-2"></i>
                    Software Update
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <span class="form-label">Huidige versie:</span>
                    <span class="ms-2 fw-bold">@currentVersion</span>
                </div>

                <div class="mb-3">
                    <span class="form-label">Laatste controle:</span>
                    <span class="ms-2">
                        @if (UpdateNotificationState.LastChecked.HasValue)
                        {
                            @UpdateNotificationState.LastChecked.Value.ToString("dd-MM-yyyy HH:mm")
                        }
                        else
                        {
                            <span class="text-muted">Nog niet gecontroleerd</span>
                        }
                    </span>
                </div>

                <div class="mb-3">
                    <span class="form-label">Status:</span>
                    <span class="ms-2">
                        @if (UpdateNotificationState.PendingUpdate is not null)
                        {
                            <span class="badge bg-warning text-dark">
                                <i class="fas fa-exclamation-circle me-1"></i>
                                Update beschikbaar: @UpdateNotificationState.PendingUpdate.TagName
                            </span>
                        }
                        else if (UpdateNotificationState.LastChecked.HasValue)
                        {
                            <span class="badge bg-success">
                                <i class="fas fa-check-circle me-1"></i>
                                Up-to-date
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">Onbekend</span>
                        }
                    </span>
                </div>

                @if (!string.IsNullOrWhiteSpace(updateCheckMessage))
                {
                    <div class="alert alert-info alert-dismissible fade show" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        @updateCheckMessage
                        <button type="button" class="btn-close" @onclick="() => updateCheckMessage = string.Empty" aria-label="Close"></button>
                    </div>
                }

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="includePreReleases"
                           checked="@includePreReleases"
                           @onchange="ToggleIncludePreReleasesAsync" />
                    <label class="form-check-label" for="includePreReleases">
                        Pre-releases meenemen bij het controleren op updates
                    </label>
                </div>

                <button type="button" class="btn btn-outline-primary" @onclick="CheckNowAsync" disabled="@isCheckingUpdate">
                    @if (isCheckingUpdate)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>Controleren…</span>
                    }
                    else
                    {
                        <i class="fas fa-sync-alt me-1"></i>
                        <span>Nu controleren</span>
                    }
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private ISettingsService SettingsService { get; set; } = null!;
    [Inject] private IJSRuntime JSRuntime { get; set; } = null!;
    [Inject] private IUpdateCheckService UpdateCheckService { get; set; } = null!;
    [Inject] private IUpdateNotificationState UpdateNotificationState { get; set; } = null!;

    private string databasePath = "";
    private string successMessage = "";
    private string errorMessage = "";
    private bool listenOnAllInterfaces = false;
    private bool includePreReleases = false;
    private bool isCheckingUpdate = false;
    private string updateCheckMessage = "";
    private string currentVersion = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDatabasePath();
        await LoadServerBindingSetting();
        await LoadUpdateSettings();
        currentVersion = GetCurrentVersion();
    }

    private static string GetCurrentVersion()
    {
        var v = typeof(Program).Assembly.GetName().Version;
        return v is null ? "onbekend" : $"{v.Major}.{v.Minor}.{v.Build}";
    }

    private async Task LoadUpdateSettings()
    {
        try
        {
            includePreReleases = await SettingsService.GetIncludePreReleasesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Fout bij laden update-instellingen: {ex.Message}";
        }
    }

    private async Task ToggleIncludePreReleasesAsync(ChangeEventArgs e)
    {
        includePreReleases = e.Value is bool b && b;
        try
        {
            await SettingsService.SetIncludePreReleasesAsync(includePreReleases);
        }
        catch (Exception ex)
        {
            errorMessage = $"Fout bij opslaan instelling: {ex.Message}";
        }
    }

    private async Task CheckNowAsync()
    {
        isCheckingUpdate = true;
        updateCheckMessage = "";
        try
        {
            var currentVersionParsed = typeof(Program).Assembly.GetName().Version;
            var releases = await UpdateCheckService.GetReleasesAsync();
            var latestRelease = releases
                .Where(r => !r.IsPreRelease || includePreReleases)
                .Where(r => currentVersionParsed is null || CompareVersions(r.Version, currentVersionParsed) > 0)
                .OrderByDescending(r => r.Version)
                .FirstOrDefault();

            UpdateNotificationState.SetUpdate(latestRelease, DateTime.Now);

            updateCheckMessage = latestRelease is not null
                ? $"Update beschikbaar: versie {latestRelease.TagName}."
                : "U gebruikt de nieuwste versie.";
        }
        catch (Exception ex)
        {
            updateCheckMessage = $"Fout bij controleren op updates: {ex.Message}";
        }
        finally
        {
            isCheckingUpdate = false;
        }
    }

    private static int CompareVersions(Version candidate, Version current)
    {
        var candidateNorm = new Version(candidate.Major, candidate.Minor, Math.Max(candidate.Build, 0));
        var currentNorm = new Version(current.Major, current.Minor, Math.Max(current.Build, 0));
        return candidateNorm.CompareTo(currentNorm);
    }

    private async Task LoadDatabasePath()
    {
        try
        {
            var directory = await SettingsService.GetDatabaseDirectoryAsync();
            databasePath = !string.IsNullOrWhiteSpace(directory) ? directory : "Niet geconfigureerd";
        }
        catch (Exception ex)
        {
            errorMessage = $"Fout bij laden database pad: {ex.Message}";
            databasePath = "Fout bij laden";
        }
    }

    private async Task CopyDatabasePath()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", databasePath);
            successMessage = "Pad gekopieerd naar klembord";
        }
        catch
        {
            errorMessage = "Kon pad niet kopiëren naar klembord";
        }
    }

    private async Task LoadServerBindingSetting()
    {
        try
        {
            listenOnAllInterfaces = await SettingsService.GetListenOnAllInterfacesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Fout bij laden server instellingen: {ex.Message}";
        }
    }

    private async Task UpdateServerBinding(bool value)
    {
        errorMessage = "";
        successMessage = "";
        try
        {
            await SettingsService.SetListenOnAllInterfacesAsync(value);
            listenOnAllInterfaces = value;
            successMessage = value
                ? "Server instelling bijgewerkt: Alle computers in het netwerk kunnen nu de server benaderen. Herstart de applicatie om de wijziging door te voeren."
                : "Server instelling bijgewerkt: Alleen deze computer kan nu de server benaderen. Herstart de applicatie om de wijziging door te voeren.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Fout bij bijwerken server instelling: {ex.Message}";
        }
    }
}
